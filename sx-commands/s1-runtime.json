{
    "target": "bmv2",
    "p4info": "build/prr.p4.p4info.txtpb",
    "bmv2_json": "build/prr.json",
    "table_entries": [
        {
            "table": "MyIngress.ipv4_lpm",
            "match": {
                "hdr.ipv4.dstAddr": [
                    "10.0.1.1",
                    32
                ]
            },
            "action_name": "MyIngress.set_nhop",
            "action_params": {
                "dstAddr": "00:00:0a:00:01:01",
                "port": 1
            }
        },
        {
            "table": "MyIngress.ipv4_lpm",
            "match": {
                "hdr.ipv4.dstAddr": [
                    "10.0.6.0",
                    24
                ]
            },
            "action_name": "MyIngress.set_prr_select",
            "action_params": {
                "ecmp_base": 5,
                "ecmp_count": 4,
                "switch_id": 1
            }
        },
        {
            "table": "MyIngress.prr_nhop",
            "match": {
                "meta.prr_hash": 5
            },
            "action_name": "MyIngress.set_nhop",
            "action_params": {
                "dstAddr": "08:00:00:01:02:00",
                "port": 5
            }
        },
        {
            "table": "MyIngress.prr_nhop",
            "match": {
                "meta.prr_hash": 6
            },
            "action_name": "MyIngress.set_nhop",
            "action_params": {
                "dstAddr": "08:00:00:01:03:00",
                "port": 6
            }
        },
        {
            "table": "MyIngress.prr_nhop",
            "match": {
                "meta.prr_hash": 7
            },
            "action_name": "MyIngress.set_nhop",
            "action_params": {
                "dstAddr": "08:00:00:01:04:00",
                "port": 7
            }
        },
        {
            "table": "MyIngress.prr_nhop",
            "match": {
                "meta.prr_hash": 8
            },
            "action_name": "MyIngress.set_nhop",
            "action_params": {
                "dstAddr": "08:00:00:01:05:00",
                "port": 8
            }
        }
    ]
}